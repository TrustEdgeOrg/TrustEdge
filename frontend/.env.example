# Example Environment Variables
# Copy to frontend/.env.production or set in CI before npm run build

# API Configuration — FastAPI origin only (NOT the CloudFront/S3 UI URL).
# Example: http://44.218.45.174:8000
REACT_APP_API_BASE_URL=http://your-ec2-ip:8000

# Required in production (same value as backend ADMIN_API_TOKEN)
REACT_APP_ADMIN_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET
REACT_APP_ENVIRONMENT=production

# Client map: WireGuard gateway marker + traffic arc destination (ISO country code)
# REACT_APP_VPN_GATEWAY_COUNTRY=US
# REACT_APP_VPN_GATEWAY_LABEL=VPN gateway

GENERATE_SOURCEMAP=false
